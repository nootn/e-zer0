{
    "name": "e-zer0",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "db:migrate:local": "wrangler d1 migrations apply e-zer0-db --local",
        "db:migrate:remote": "wrangler d1 migrations apply e-zer0-db --remote",
        "db:reset:local": "rd /s /q .wrangler\\\\state 2>nul & echo Local DB wiped. && npm run db:migrate:local",
        "db:reset:local:unix": "rm -rf .wrangler/state && echo 'Local DB wiped.' && npm run db:migrate:local",
        "db:studio": "wrangler d1 execute e-zer0-db --local --command \"SELECT name FROM sqlite_master WHERE type='table'\"",
        "setup-cf": "node scripts/setup-cf.js",
        "typecheck": "tsc --noEmit",
        "lint": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "format": "prettier --write \"src/**/*.{ts,tsx}\" \"*.{json,md}\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"*.{json,md}\"",
        "check": "npm run format && npm run lint && npm run test",
        "ci:check": "npm ci && npm run check"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1",
        "hono": "^4.12.16",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260305.0",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18",
        "wrangler": "^4.69.0"
    }
}
